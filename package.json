{
  "name": "nestro",
  "displayName": "Nestro",
  "description": "Manage npm/pnpm/yarn packages from the VS Code sidebar with update status and version switching",
  "version": "0.0.1",
  "publisher": "greentech-solutions",
  "icon": "resources/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GreenTech-Solutions/nestro.git"
  },
  "keywords": [
    "npm",
    "pnpm",
    "yarn",
    "bun",
    "packages",
    "dependencies",
    "update",
    "manager",
    "sidebar",
    "audit"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.cjs",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nestro",
          "title": "Nestro",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "nestro": [
        {
          "id": "nestro.packagesView",
          "name": "Packages",
          "when": "workbenchState != empty",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "nestro.packagesView",
        "contents": "No Node.js project found in the workspace.\n[Open Folder](command:vscode.openFolder)",
        "when": "nestro.noWorkspace"
      }
    ],
    "configuration": {
      "title": "Nestro",
      "properties": {
        "nestro.checkUpdatesOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Automatically check for package updates when the extension activates."
        },
        "nestro.includePreReleases": {
          "type": "boolean",
          "default": true,
          "description": "Include pre-release versions when checking for package updates."
        },
        "nestro.updateTarget": {
          "type": "string",
          "enum": [
            "latest",
            "greatest",
            "minor",
            "patch"
          ],
          "default": "latest",
          "description": "Version target strategy for update checks."
        },
        "nestro.defaultFilter": {
          "type": "string",
          "enum": [
            "all",
            "hasUpdates",
            "patch",
            "minor",
            "breaking"
          ],
          "default": "all",
          "description": "Default package sidebar filter."
        },
        "nestro.deferInstallAfterUpdate": {
          "type": "boolean",
          "default": false,
          "description": "Update package.json first and run dependency installation separately."
        },
        "nestro.confirmBulkUpdate": {
          "type": "boolean",
          "default": true,
          "description": "Show confirmation dialog before updating all visible packages."
        },
        "nestro.runAuditOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Run npm audit automatically when the extension activates."
        },
        "nestro.monorepoGlob": {
          "type": "string",
          "default": "**/package.json",
          "description": "Glob used to discover package.json files in the workspace."
        }
      }
    },
    "commands": [
      {
        "command": "nestro.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "nestro.checkUpdates",
        "title": "Check for Updates",
        "icon": "$(cloud-download)"
      },
      {
        "command": "nestro.runAudit",
        "title": "Run Security Audit",
        "icon": "$(shield)"
      },
      {
        "command": "nestro.installUpdate",
        "title": "Update Package",
        "icon": "$(arrow-up)"
      },
      {
        "command": "nestro.pickVersion",
        "title": "Pick Version...",
        "icon": "$(list-unordered)"
      },
      {
        "command": "nestro.switchDepType",
        "title": "Switch to dev/dep",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "nestro.pinVersion",
        "title": "Toggle version pin",
        "icon": "$(lock)"
      },
      {
        "command": "nestro.updateAllVisible",
        "title": "Update All",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "nestro.runInstall",
        "title": "Run Install",
        "icon": "$(terminal)"
      },
      {
        "command": "nestro.openOnNpm",
        "title": "Open on npmjs.com",
        "icon": "$(link-external)"
      },
      {
        "command": "nestro.copyPackageName",
        "title": "Copy Package Name",
        "icon": "$(copy)"
      },
      {
        "command": "nestro.openSettings",
        "title": "Settings",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "nestro.refresh",
          "when": "view == nestro.packagesView",
          "group": "navigation"
        },
        {
          "command": "nestro.checkUpdates",
          "when": "view == nestro.packagesView",
          "group": "navigation"
        },
        {
          "command": "nestro.runAudit",
          "when": "view == nestro.packagesView",
          "group": "navigation@5"
        },
        {
          "command": "nestro.updateAllVisible",
          "when": "view == nestro.packagesView && nestro.canUpdateVisiblePackages",
          "group": "navigation"
        },
        {
          "command": "nestro.runInstall",
          "when": "view == nestro.packagesView",
          "group": "navigation"
        },
        {
          "command": "nestro.openSettings",
          "when": "view == nestro.packagesView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "nestro.installUpdate",
          "when": "view == nestro.packagesView && viewItem == outdated",
          "group": "inline"
        },
        {
          "command": "nestro.pickVersion",
          "when": "view == nestro.packagesView && viewItem =~ /^(package|outdated)/",
          "group": "inline@2"
        },
        {
          "command": "nestro.openOnNpm",
          "when": "view == nestro.packagesView && viewItem =~ /^(package|outdated|installing)/",
          "group": "inline@3"
        },
        {
          "command": "nestro.switchDepType",
          "when": "view == nestro.packagesView && viewItem =~ /^(package|outdated)/",
          "group": "inline@4"
        },
        {
          "command": "nestro.pinVersion",
          "when": "view == nestro.packagesView && viewItem =~ /^(package|outdated)/",
          "group": "inline@5"
        },
        {
          "command": "nestro.copyPackageName",
          "when": "view == nestro.packagesView && viewItem =~ /^(package|outdated|installing)/",
          "group": "navigation@2"
        },
        {
          "command": "nestro.switchDepType",
          "when": "view == nestro.packagesView && viewItem =~ /^(package|outdated)/",
          "group": "2_manage@1"
        },
        {
          "command": "nestro.pinVersion",
          "when": "view == nestro.packagesView && viewItem =~ /^(package|outdated)/",
          "group": "2_manage@2"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "vscode:prepublish": "pnpm run build",
    "pretest": "tsc -p tsconfig.test.json && pnpm run lint",
    "typecheck": "tsc --noEmit",
    "lint:eslint": "eslint --fix --cache src",
    "lint": "pnpm run lint:eslint",
    "test": "vscode-test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "npm-run-all2": "^9.0.1",
    "semantic-release": "^25.0.3",
    "semantic-release-vsce": "^6.1.5",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.7"
  },
  "type": "commonjs",
  "packageManager": "pnpm@11.0.8",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@vscode/vsce-sign",
      "keytar"
    ]
  },
  "dependencies": {
    "npm-check-updates": "^22.2.1"
  }
}
